# Frontend Environment Variables
# Copy this to .env.local for local development
# Set VITE_API_URL in Vercel dashboard for production

# Local development (default — no need to set)
VITE_API_URL=http://localhost:5000/api/auth

# Production — replace with your actual Vercel backend URL after deploying server
# VITE_API_URL=https://your-backend.vercel.app/api/auth
