# ── Server Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values

PORT=5000

# MySQL Database (use PlanetScale / Railway / Clever Cloud for production)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=antigrav-users

# JWT Secret (use a long random string in production)
JWT_SECRET=antigravitywebapp1_jwt_secret_2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
